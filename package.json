{
  "name": "@xquik/tweetclaw",
  "version": "1.0.0",
  "description": "X/Twitter automation for OpenClaw — search, post, extract, draw, monitor via Xquik",
  "license": "MIT",
  "type": "module",
  "openclaw": {
    "extensions": ["./src/index.ts"]
  },
  "files": ["src/", "openclaw.plugin.json"],
